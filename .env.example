# ============================================================
# Neural Hub — Environment Variables Template
# Copy to backend/.env and fill in your real values
# NEVER commit the actual .env file
# ============================================================

# ─── App Settings ────────────────────────────────────────────
APP_NAME="Neural Hub AI Medical Coder"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# ─── Security (REQUIRED) ─────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key-32-chars-minimum

# ─── LLM Provider ────────────────────────────────────────────
# For Railway: use openai (Ollama requires local GPU/CPU)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenAI API Key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local only — not used on Railway)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Embeddings ──────────────────────────────────────────────
# Use all-MiniLM-L6-v2 for Railway (fast, ~80MB download)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Database ────────────────────────────────────────────────
# Local SQLite:
DATABASE_URL=sqlite+aiosqlite:///./data/medical_coder.db
# Railway PostgreSQL (use Railway's provided DATABASE_URL variable):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ─── CORS ────────────────────────────────────────────────────
# Local dev:
CORS_ORIGINS=http://localhost:3000
# Railway production (set to true, or list your frontend URL):
CORS_ALLOW_ALL_ORIGINS=false
# CORS_ORIGINS=https://your-frontend.railway.app

# ─── Vector Store ────────────────────────────────────────────
CHROMA_PERSIST_DIR=./knowledge_base/indices
CHROMA_COLLECTION_ICD10=icd10_codes
CHROMA_COLLECTION_CPT=cpt_codes
CHROMA_COLLECTION_HCPCS=hcpcs_codes

# ─── Coding Settings ─────────────────────────────────────────
MAX_CODES_PER_REQUEST=20
MIN_CONFIDENCE_THRESHOLD=0.70
AUTO_APPROVE_THRESHOLD=0.90
HUMAN_REVIEW_THRESHOLD=0.70
RAG_TOP_K=15

# ─── Human Review ────────────────────────────────────────────
REVIEW_QUEUE_ENABLED=true
AUTO_EXPIRE_HOURS=72
