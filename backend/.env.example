# Copy this file to .env and fill in your values
# NEVER commit .env to version control

APP_NAME=AI Medical Coder
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
JSON_LOGS=false

# Security — REQUIRED
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_WITH_python_-c_import_secrets_print_secrets_token_hex_32

# PHI Encryption key (32 bytes, base64-encoded)
# Generate: python -c "from app.utils.encryption import PHIEncryption; print(PHIEncryption.generate_key_b64())"
PHI_ENCRYPTION_KEY=
ENABLE_PHI_ENCRYPTION=false

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=sqlite+aiosqlite:///./data/medical_coder.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://medcoder:YOUR_PASSWORD@localhost:5432/medical_coder

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120

EMBEDDING_MODEL=all-MiniLM-L6-v2

CHROMA_PERSIST_DIR=./knowledge_base/indices
CHROMA_COLLECTION_ICD10=icd10_codes
CHROMA_COLLECTION_CPT=cpt_codes
CHROMA_COLLECTION_HCPCS=hcpcs_codes

KNOWLEDGE_BASE_DIR=./knowledge_base/data
ICD10_DATA_DIR=./knowledge_base/data/icd10
CPT_DATA_DIR=./knowledge_base/data/cpt
HCPCS_DATA_DIR=./knowledge_base/data/hcpcs

MAX_CODES_PER_REQUEST=20
MIN_CONFIDENCE_THRESHOLD=0.70
AUTO_APPROVE_THRESHOLD=0.90
HUMAN_REVIEW_THRESHOLD=0.70
RAG_TOP_K=15
RAG_SIMILARITY_THRESHOLD=0.3

SCISPACY_MODEL=en_core_sci_lg
ENABLE_UMLS_LINKING=false

MAX_DOCUMENT_SIZE_MB=50
SUPPORTED_FORMATS=pdf,txt,docx,png,jpg,jpeg,tiff
TESSERACT_CMD=tesseract
OCR_LANGUAGE=eng

REVIEW_QUEUE_ENABLED=true
AUTO_EXPIRE_HOURS=72

CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

REDIS_URL=redis://localhost:6379
RATE_LIMIT_REQUESTS_PER_MINUTE=60

API_KEY_HEADER=X-API-Key
ALLOWED_API_KEYS=
